generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Tabel USERS
model users {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar
  password_hash String    @db.VarChar
  full_name     String    @db.VarChar
  last_login    DateTime? @db.Timestamp
  created_at    DateTime  @default(now()) @db.Timestamp

  devices       devices[] // Relasi ke tabel devices
}

// 2. Tabel DEVICES
model devices {
  id            String    @id @default(uuid()) @db.Uuid
  device_name   String    @db.VarChar
  location      String    @db.VarChar
  mac_address   String    @unique @db.VarChar
  is_active     Boolean   @default(true)
  registered_by String    @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamp

  user          users     @relation(fields: [registered_by], references: [id], onDelete: Cascade)
  sensor_logs   sensor_logs[]
}

// 3. Tabel SENSOR_LOGS
model sensor_logs {
  id                  BigInt    @id @default(autoincrement())
  device_id           String    @db.Uuid
  tvoc_pb             Float
  eco2_ppm            Float
  dust_density_ugm3   Float?    // Opsional, disesuaikan jika sensor debu belum ada
  temperature_celsius Float
  humidity_percent    Float
  fan_duty_cycle      Int
  recorded_at         DateTime  @default(now()) @db.Timestamp

  device              devices   @relation(fields: [device_id], references: [id], onDelete: Cascade)
  predictions         air_quality_predictions[]
}

// 4. Tabel AIR_QUALITY_PREDICTIONS
model air_quality_predictions {
  id                    BigInt    @id @default(autoincrement())
  sensor_log_id         BigInt
  status_label          String    @db.VarChar
  confidence_aman       Float
  confidence_waspada   Float
  confidence_berbahaya  Float
  predicted_at          DateTime  @default(now()) @db.Timestamp

  sensor_log            sensor_logs @relation(fields: [sensor_log_id], references: [id], onDelete: Cascade)
}